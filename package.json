{
  "name": "micro-batch-store",
  "version": "0.0.1",
  "author": "Mateusz Sikora (sikora.software)",
  "description": "Minimal Redux-like store with microtask-batched notifications",
  "keywords": [
    "redux",
    "store",
    "state-management",
    "microtask",
    "queueMicrotask",
    "batching",
    "batched-updates",
    "lightweight",
    "tiny-redux",
    "performance",
    "typescript"
  ],
  "homepage": "https://github.com/sikora-software/micro-batch-store#readme",
  "bugs": {
    "url": "https://github.com/sikora-software/micro-batch-store/issues"
  },
  "license": "MIT",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=24",
    "pnpm": "11.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sikora-software/micro-batch-store.git"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --clean --define.PACKAGE_VERSION \"\\\"$npm_package_version\\\"\" && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "dev": "tsup src/index.ts --format cjs,esm --watch --define.PACKAGE_VERSION \"\\\"$npm_package_version\\\"\"",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.7"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ]
}
